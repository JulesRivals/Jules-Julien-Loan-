package java_projet;

import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.ResultSet;
import java.sql.Statement;

public class Main {
    public static void main(String[] args) {

        String url = "jdbc:sqlite:BDD_Java_Projet.db";

        try {
            Connection conn = DriverManager.getConnection(url);
            System.out.println("Connexion OK");

            Statement stmt = conn.createStatement();

            
            stmt.execute("CREATE TABLE IF NOT EXISTS utilisateurs (" +
                         "id INTEGER PRIMARY KEY AUTOINCREMENT, " +
                         "nom TEXT)");
            System.out.println("Table prête");

            // Insertion
            int rows = stmt.executeUpdate(
                "INSERT INTO utilisateurs(nom) VALUES ('Alice')");
            System.out.println(rows + " ligne insérée");

            // Lecture
            ResultSet rs = stmt.executeQuery("SELECT * FROM utilisateurs");

            while (rs.next()) {
                System.out.println(
                    "ID: " + rs.getInt("id") +
                    " | Nom: " + rs.getString("nom"));
            }

            conn.close();

        } catch (Exception e) {
            e.printStackTrace();
        }
    }
}
